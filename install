#!/usr/bin/env python3
"""Hashbuild skill installer / uninstaller."""

import argparse
import json
import os
import sys
from collections.abc import Sequence
from dataclasses import dataclass, field
from enum import Enum
from pathlib import Path
from typing import Any, Literal, NoReturn

PROJECT_ROOT = Path(__file__).resolve().parent


@dataclass(frozen=True)
class HarnessConfig:
    path_base: Path
    path_skills: Path
    path_perm_skills: Path

    path_settings: Path | None
    """settings.json path per harness; None = no permission patching for that harness"""


class HarnessKey(Enum):
    Claude = "claude"
    OpenCode = "opencode"

    def __str__(self) -> str:
        return self.value


@dataclass(frozen=True)
class ValidHarnesses:
    harnesses: tuple[HarnessKey, ...] = field(default_factory=tuple)


HARNESS_CLAUDE = HarnessKey("claude")
HARNESS_OPENCODE = HarnessKey("opencode")

# Base dir that must already exist (signals harness is installed).
# Skills subdir is created if absent.
HARNESSES: dict[HarnessKey, HarnessConfig] = {
    HARNESS_CLAUDE: HarnessConfig(
        path_base=Path.home() / ".claude",
        path_skills=Path.home() / ".claude" / "skills",
        path_perm_skills=Path("~") / ".claude" / "skills",
        path_settings=Path.home() / ".claude" / "settings.json",
    ),
    HARNESS_OPENCODE: HarnessConfig(
        path_base=Path.home() / ".config" / "opencode",
        path_skills=Path.home() / ".config" / "opencode" / "skills",
        path_perm_skills=Path("~") / ".config" / "opencode" / "skills",
        path_settings=Path.home() / ".config" / "opencode" / "opencode.json",
    ),
}

HB_FLOW_HOOK_MATCHER = "startup|clear"
HB_FLOW_HOOK_MARKER = "run /hb-flow to see what to do next."
"""Substring identifying an hb-flow SessionStart hook entry regardless of command formatting.

Entries are matched on this marker rather than exact command equality so that
changes to HB_FLOW_HOOK_COMMAND upgrade an existing entry in place instead of
adding a duplicate (install) or leaving a stale entry behind (uninstall).
"""
HB_FLOW_HOOK_COMMAND = (
    '[ -d .hb ] && echo \'{"systemMessage": "hashbuild: run /hb-flow to see what to do next."}\'; true'
)

# ── helpers ───────────────────────────────────────────────────────────────────


def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def info(msg: str) -> None:
    print(msg)


def _detect_harnesses() -> ValidHarnesses:
    return ValidHarnesses(tuple(key for key, cfg in HARNESSES.items() if cfg.path_base.is_dir()))


def _prompt_harnesses(found: ValidHarnesses) -> ValidHarnesses:
    info(f"Detected harnesses: {', '.join(str(h) for h in found.harnesses)}")
    try:
        resp = input("Target all? [Y/n] ").strip().lower()
    except EOFError:
        return found

    if resp in ("", "y", "yes"):
        return found

    try:
        raw = input(f"Enter comma-separated subset ({', '.join(str(h) for h in found.harnesses)}): ")
    except EOFError:
        return found

    picks = [HarnessKey(p.strip()) for p in raw.split(",") if p.strip()]
    if not picks:
        die("no harnesses selected")

    return _parse_harness_selection(picks, found)


def _parse_harness_selection(picks: Sequence[HarnessKey], found: ValidHarnesses) -> ValidHarnesses:
    unknown = [p for p in picks if p not in HARNESSES]
    if unknown:
        die(f"unknown harness(es): {', '.join(str(h) for h in unknown)}")

    not_found = [p for p in picks if p not in found.harnesses]
    if not_found:
        die(
            f"harness base dir not found for: {', '.join(str(h) for h in not_found)}\n"
            f"  ensure the harness is installed before installing hashbuild to it"
        )

    return ValidHarnesses(tuple(picks))


def _src_skills_dir() -> Path:
    skills_dir = PROJECT_ROOT / "skills"
    if not skills_dir.is_dir():
        die(f"skills/ directory not found at {skills_dir}")

    return skills_dir


def _skill_files() -> list[Path]:
    skills_dir = _src_skills_dir()
    files = sorted(skills_dir.glob("*.md"))
    if not files:
        die(f"no .md files found in {skills_dir}")
    return files


def _check_symlink(link: Path, expected_target: Path) -> None:
    """
    Ensure link is a symlink pointing to expected_target.
    Raises SystemExit with remediation steps on conflict.
    """

    label = link.name

    if link.is_symlink():
        actual = Path(os.readlink(link))
        if actual == expected_target:
            return  # already correct — idempotent

        print(
            f"\nerror: symlink conflict ({label})\n"
            f"  path:             {link}\n"
            f"  expected target:  {expected_target}\n"
            f"  actual target:    {actual}\n"
            f"  remediation:      remove {link} then re-run install",
            file=sys.stderr,
        )
        sys.exit(1)

    if link.exists():
        print(
            f"\nerror: path conflict — not a symlink ({label})\n"
            f"  path:             {link}\n"
            f"  expected:         symlink → {expected_target}\n"
            f"  actual:           existing {'directory' if link.is_dir() else 'file'}\n"
            f"  remediation:      remove {link} then re-run install",
            file=sys.stderr,
        )
        sys.exit(1)

    link.symlink_to(expected_target)


# ── settings permission patching ─────────────────────────────────────────────


@dataclass
class SettingsUpdateResult:
    path_settings: Path = field(default_factory=Path)
    perms_added: list[str] = field(default_factory=list[str])
    perms_removed: list[str] = field(default_factory=list[str])
    updated_settings: dict[str, Any] = field(default_factory=dict[str, Any])

    def __bool__(self) -> bool:
        return bool(self.perms_added or self.perms_removed)

    def flush(self) -> None:
        """Write results to disk"""

        if not self.updated_settings:
            die("empty settings data; nothing to write")

        self.path_settings.write_text(json.dumps(self.updated_settings, indent=2) + "\n")


class SettingsPatcher:
    _harness: HarnessKey
    _skill_names: list[str]
    _src_skills_dir: Path

    def __init__(self, harness: HarnessKey, src_skills_dir: Path, skill_names: list[str]) -> None:
        self._harness = harness
        self._skill_names = skill_names
        self._src_skills_dir = src_skills_dir

    def _permission_entries(self) -> list[str]:
        perms = list[str]()
        for name in self._skill_names:
            match self._harness:
                # Add individual skill directories and resolved path
                case HarnessKey.Claude:
                    cfg = HARNESSES[HARNESS_CLAUDE]
                    target = str(cfg.path_perm_skills / name / "**")
                    perm = f"Read({target})"
                    perms.append(perm)

                case HarnessKey.OpenCode:
                    cfg = HARNESSES[HARNESS_OPENCODE]
                    perm = str(cfg.path_perm_skills / name / "*")
                    perms.append(perm)

                case _:
                    raise ValueError(self._harness)

        match self._harness:
            case HarnessKey.Claude:
                target = "/" + str(self._src_skills_dir.resolve() / "**")
                perm = f"Read({target})"
                perms.append(perm)

            case HarnessKey.OpenCode:
                perm = str(self._src_skills_dir / "*")
                perms.append(perm)

            case _:
                raise ValueError(self._harness)

        return perms

    def _read_settings(self) -> dict[str, Any]:
        cfg = HARNESSES[self._harness]
        path_settings = cfg.path_settings
        if not path_settings or not path_settings.exists():
            return dict()

        data: dict[str, Any] = json.loads(path_settings.read_text())
        return data

    def _update(self, action: Literal["install", "uninstall"]) -> SettingsUpdateResult:
        cfg = HARNESSES[self._harness]
        path_settings = cfg.path_settings
        if not path_settings:
            die(f"settings path not found for harness {self._harness}")

        data = self._read_settings()
        entries = self._permission_entries()
        result = SettingsUpdateResult(
            path_settings=path_settings,
            updated_settings=data,
        )

        match self._harness:
            case HarnessKey.Claude:
                allow_cl: list[str] = data.setdefault("permissions", {}).setdefault("allow", [])
                existing = set(allow_cl)
                match action:
                    case "install":
                        result.perms_added = sorted(e for e in entries if e not in existing)
                        allow_cl.extend(result.perms_added)

                    case "uninstall":
                        result.perms_removed = sorted(e for e in entries if e in existing)
                        for e in result.perms_removed:
                            allow_cl.remove(e)

            case HarnessKey.OpenCode:
                allow_oc: dict[str, str] = data.setdefault("permission", {}).setdefault("read", {})
                match action:
                    case "install":
                        result.perms_added = sorted(e for e in entries if e not in allow_oc)
                        for e in result.perms_added:
                            allow_oc[e] = "allow"

                    case "uninstall":
                        result.perms_removed = sorted(e for e in entries if e in allow_oc)
                        for e in result.perms_removed:
                            del allow_oc[e]

            case _:
                raise ValueError(self._harness)

        return result

    def install(self) -> SettingsUpdateResult:
        return self._update("install")

    def uninstall(self) -> SettingsUpdateResult:
        return self._update("uninstall")


@dataclass
class HookUpdateResult:
    path_settings: Path = field(default_factory=Path)
    hook_added: bool = False
    hook_updated: bool = False
    hook_removed: bool = False
    updated_settings: dict[str, Any] = field(default_factory=dict[str, Any])

    def __bool__(self) -> bool:
        return bool(self.hook_added or self.hook_updated or self.hook_removed)

    def flush(self) -> None:
        """Write results to disk"""

        self.path_settings.write_text(json.dumps(self.updated_settings, indent=2) + "\n")


class HookPatcher:
    """Patches the `/hb-flow` SessionStart hook into a Claude harness's settings.json."""

    _path_settings: Path

    def __init__(self, path_settings: Path) -> None:
        self._path_settings = path_settings

    def _read_settings(self) -> dict[str, Any]:
        if not self._path_settings.exists():
            return dict()

        data: dict[str, Any] = json.loads(self._path_settings.read_text())
        return data

    def _find_matcher_group(self, data: dict[str, Any]) -> dict[str, Any] | None:
        groups: list[dict[str, Any]] = data.get("hooks", {}).get("SessionStart", [])
        for group in groups:
            if group.get("matcher") == HB_FLOW_HOOK_MATCHER:
                return group

        return None

    def _find_hook_entry(self, group: dict[str, Any]) -> dict[str, Any] | None:
        for entry in group.get("hooks", []):
            if entry.get("type") == "command" and HB_FLOW_HOOK_MARKER in entry.get("command", ""):
                return entry

        return None

    def install(self) -> HookUpdateResult:
        data = self._read_settings()
        result = HookUpdateResult(path_settings=self._path_settings, updated_settings=data)

        group = self._find_matcher_group(data)
        if group is not None:
            entry = self._find_hook_entry(group)
            if entry is not None:
                if entry.get("command") == HB_FLOW_HOOK_COMMAND:
                    return result

                entry["command"] = HB_FLOW_HOOK_COMMAND
                result.hook_updated = True
                return result

            group.setdefault("hooks", []).append({"type": "command", "command": HB_FLOW_HOOK_COMMAND})
            result.hook_added = True
            return result

        session_start: list[dict[str, Any]] = data.setdefault("hooks", {}).setdefault("SessionStart", [])
        session_start.append(
            {
                "matcher": HB_FLOW_HOOK_MATCHER,
                "hooks": [{"type": "command", "command": HB_FLOW_HOOK_COMMAND}],
            }
        )
        result.hook_added = True
        return result

    def uninstall(self) -> HookUpdateResult:
        data = self._read_settings()
        result = HookUpdateResult(path_settings=self._path_settings, updated_settings=data)

        group = self._find_matcher_group(data)
        if group is None:
            return result

        entry = self._find_hook_entry(group)
        if entry is None:
            return result

        group["hooks"].remove(entry)
        result.hook_removed = True

        if not group["hooks"]:
            data["hooks"]["SessionStart"].remove(group)

        if not data["hooks"]["SessionStart"]:
            del data["hooks"]["SessionStart"]

        if not data["hooks"]:
            del data["hooks"]

        return result


def _confirm(prompt: str) -> bool:
    try:
        resp = input(prompt).strip().lower()
    except EOFError:
        return True
    return resp in ("", "y", "yes")


# ── install / uninstall ───────────────────────────────────────────────────────


def _install_skill(src_skill_file: Path, dst_skills_dir: Path) -> None:
    skill_name = src_skill_file.stem
    dst_skill_dir = dst_skills_dir / skill_name
    dst_skill_dir.mkdir(parents=True, exist_ok=True)

    src_skill_dir = src_skill_file.parent

    _check_symlink(dst_skill_dir / "SKILL.md", src_skill_file.resolve())
    _check_symlink(dst_skill_dir / "references", (src_skill_dir / "references").resolve())
    _check_symlink(dst_skill_dir / "scripts", (src_skill_dir / "scripts").resolve())

    info(f"    [ok] {skill_name}")


def _uninstall_skill(skill_file: Path, skills_dir: Path) -> None:
    skill_name = skill_file.stem
    skill_dir = skills_dir / skill_name

    if not skill_dir.exists() and not skill_dir.is_symlink():
        info(f"    [skip] {skill_name} — not installed")
        return

    for entry_name in ("SKILL.md", "references", "scripts"):
        entry = skill_dir / entry_name
        if entry.is_symlink():
            entry.unlink()
        elif entry.exists():
            print(
                f"\nerror: unexpected non-symlink during uninstall\n"
                f"  path:        {entry}\n"
                f"  expected:    symlink (created by install)\n"
                f"  remediation: manually inspect and remove {entry}",
                file=sys.stderr,
            )
            sys.exit(1)

    remaining = list(skill_dir.iterdir())
    if remaining:
        info(
            f"    [warn] {skill_name} — extra files remain, leaving directory:\n"
            + "\n".join(f"      {p}" for p in remaining)
        )
    else:
        skill_dir.rmdir()
        info(f"    [ok] removed {skill_name}")


def run_install(picks: ValidHarnesses) -> None:
    src_skill_files = _skill_files()
    for i, harness in enumerate(picks.harnesses):
        if i > 0:
            info("")

        cfg = HARNESSES[harness]
        base = cfg.path_base
        dst_skills_dir: Path = cfg.path_skills
        settings_path = cfg.path_settings

        if not base.is_dir():
            die(
                f"harness base directory not found: {base}\n"
                f"  ensure {harness} is installed before running this script"
            )

        dst_skills_dir.mkdir(parents=True, exist_ok=True)
        info(f"  harness: {harness} ({dst_skills_dir})")

        for src_skill_file in src_skill_files:
            _install_skill(src_skill_file, dst_skills_dir)

        if settings_path is not None:
            names = [f.stem for f in src_skill_files]
            patcher = SettingsPatcher(harness, _src_skills_dir(), names)
            result = patcher.install()
            if not result:
                info(f"  [skip] read permissions already present in {settings_path}")
            else:
                info(f"\n  The following read permissions will be added to {settings_path}:")
                for e in result.perms_added:
                    info(f"    {e}")
                if _confirm("  Apply? [Y/n] "):
                    result.flush()
                    info(f"  [ok] patched {settings_path}")
                else:
                    info("  [skip] skipped settings patch")

        if harness is HARNESS_CLAUDE and settings_path is not None:
            hook_patcher = HookPatcher(settings_path)
            hook_result = hook_patcher.install()
            if not hook_result:
                info(f"  [skip] /hb-flow session-start hook already present in {settings_path}")
            else:
                verb = "updated" if hook_result.hook_updated else "added"
                info(f"\n  The following hook will be {verb} in {settings_path}:")
                info(f"    SessionStart ({HB_FLOW_HOOK_MATCHER}): {HB_FLOW_HOOK_COMMAND}")
                if _confirm("  Apply? [Y/n] "):
                    hook_result.flush()
                    info(f"  [ok] patched {settings_path}")
                else:
                    info("  [skip] skipped hook patch")


def run_uninstall(picks: ValidHarnesses) -> None:
    skill_files = _skill_files()
    for i, harness in enumerate(picks.harnesses):
        if i > 0:
            info("")

        cfg = HARNESSES[harness]
        skills_dir = cfg.path_skills
        settings_path = cfg.path_settings
        info(f"  harness: {harness} ({skills_dir})")

        if not skills_dir.exists():
            info("    [skip] skills dir does not exist")
        else:
            for skill_file in skill_files:
                _uninstall_skill(skill_file, skills_dir)

        if settings_path is not None:
            names = [f.stem for f in skill_files]
            patcher = SettingsPatcher(harness, _src_skills_dir(), names)
            result = patcher.uninstall()
            if not result:
                info(f"  [skip] no matching permissions found in {settings_path}")
            else:
                info(f"\n  The following read permissions will be removed from {settings_path}:")
                for e in result.perms_removed:
                    info(f"    {e}")
                if _confirm("  Remove? [Y/n] "):
                    result.flush()
                    info(f"  [ok] cleaned {settings_path}")
                else:
                    info("  [skip] skipped settings cleanup")

        if harness is HARNESS_CLAUDE and settings_path is not None:
            hook_patcher = HookPatcher(settings_path)
            hook_result = hook_patcher.uninstall()
            if not hook_result:
                info(f"  [skip] no /hb-flow session-start hook found in {settings_path}")
            else:
                info(f"\n  The following hook will be removed from {settings_path}:")
                info(f"    SessionStart ({HB_FLOW_HOOK_MATCHER}): {HB_FLOW_HOOK_COMMAND}")
                if _confirm("  Remove? [Y/n] "):
                    hook_result.flush()
                    info(f"  [ok] cleaned {settings_path}")
                else:
                    info("  [skip] skipped hook cleanup")


# ── main ──────────────────────────────────────────────────────────────────────


def main() -> None:
    harnessess_str = [str(h) for h in HARNESSES]
    parser = argparse.ArgumentParser(description="Install or uninstall Hashbuild skills into LLM harnesses.")
    parser.add_argument(
        "--harness",
        metavar="NAME",
        choices=harnessess_str,
        action="append",
        dest="harnesses",
        help=f"target harness ({', '.join(harnessess_str)}); repeat for multiple; default: auto-detect",
    )
    parser.add_argument(
        "--uninstall",
        action="store_true",
        help="remove installed skills instead of installing",
    )
    args = parser.parse_args()

    found = _detect_harnesses()
    if not found:
        die(
            "no supported harnesses detected\n"
            + "\n".join(f"  {name}: {cfg.path_base} (not found)" for name, cfg in HARNESSES.items())
        )

    harnesses = ValidHarnesses()
    if args.harnesses:
        picks = [HarnessKey(h) for h in args.harnesses]
        harnesses = _parse_harness_selection(picks, found)
    else:
        harnesses = _prompt_harnesses(found)

    action = "Uninstalling" if args.uninstall else "Installing"
    info(f"{action} skills from {PROJECT_ROOT / 'skills'}")

    if args.uninstall:
        run_uninstall(harnesses)
    else:
        run_install(harnesses)

    info("Done.")


if __name__ == "__main__":
    main()
